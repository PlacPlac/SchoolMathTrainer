<Window x:Class="StudentApp.Views.StudentShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:StudentApp.Views"
        mc:Ignorable="d"
        Title="School Math Trainer - Student"
        Width="1160"
        Height="900"
        MinWidth="980"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{StaticResource PageBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="{Binding HeaderText}" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Sčítání a odčítání do 20 pro začátečníky i pokročilé." Style="{StaticResource SubtitleStyle}" />
            </StackPanel>
        </Border>

        <views:StudentLoginView Grid.Row="1" Margin="0,10,0,8" DataContext="{Binding Login}" />

        <ScrollViewer Grid.Row="2"
                      Margin="0,0,0,8"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel Orientation="Horizontal">
                <Button Content="Začátečník" Command="{Binding ShowBeginnerCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Width="176" />
                <Button Content="Pokročilý" Command="{Binding ShowAdvancedCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Width="168" />
                <Button Content="Můj výsledek" Command="{Binding ShowMyResultsCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Width="180" />
                <Button Content="Třídní výsledky" Command="{Binding ShowClassResultsCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Width="190" />
                <Button Content="Nová hra" Command="{Binding NewGameCommand}" Style="{StaticResource AnswerButtonStyle}" Margin="0,0,8,0" Width="156" />
                <Button Content="Změnit žáka" Command="{Binding ChangeStudentCommand}" Style="{StaticResource AnswerButtonStyle}" Margin="0,0,8,0" Width="180" />
                <Button Content="Zavřít" Command="{Binding CloseCommand}" Style="{StaticResource AnswerButtonStyle}" Margin="0" Width="138" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="28"
                VerticalAlignment="Top">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center"
                        MaxWidth="720">
                <TextBlock Text="Nejdřív se přihlas"
                           Style="{StaticResource SectionTitleStyle}"
                           TextAlignment="Center"
                           Margin="0,0,0,10" />
                <TextBlock Text="Hry a výsledky se zpřístupní až po úspěšném přihlášení přes přihlašovací kód a PIN."
                           Style="{StaticResource SubtitleStyle}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="3"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
            <TabControl.Style>
                <Style TargetType="TabControl" BasedOn="{StaticResource FriendlyTabControlStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <TabItem Header="Začátečník">
                <views:BeginnerQuizView DataContext="{Binding BeginnerQuiz}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch" />
            </TabItem>
            <TabItem Header="Pokročilý">
                <views:AdvancedDragDropView DataContext="{Binding AdvancedDragDrop}" />
            </TabItem>
            <TabItem Header="Můj výsledek">
                <views:MyResultsView DataContext="{Binding MyResults}" />
            </TabItem>
            <TabItem Header="Třídní výsledky">
                <views:ClassResultsView DataContext="{Binding ClassResults}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
