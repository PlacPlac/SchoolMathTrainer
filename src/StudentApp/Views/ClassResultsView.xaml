<UserControl x:Class="StudentApp.Views.ClassResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}"
            Margin="12"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="T&#x159;&#xED;dn&#xED; v&#xFD;sledky" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="P&#x159;ehled v&#x161;ech &#x17E;&#xE1;k&#x16F; bez administr&#xE1;torsk&#xFD;ch funkc&#xED;." Style="{StaticResource SubtitleStyle}" />
                <WrapPanel Margin="0,12,0,0">
                    <TextBox Width="260"
                             Margin="0,0,12,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Width="180"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSort}" />
                </WrapPanel>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      Margin="0,20,0,0"
                      ItemsSource="{Binding ClassItems}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      HorizontalAlignment="Stretch"
                      HorizontalScrollBarVisibility="Auto"
                      ColumnWidth="SizeToHeader">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Jm&#xE9;no nebo ID"
                                        Binding="{Binding DisplayName}"
                                        Width="2.3*"
                                        MinWidth="180" />
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding StudentId}"
                                        Width="1.2*"
                                        MinWidth="90" />
                    <DataGridTextColumn Header="Vy&#x159;e&#x161;eno"
                                        Binding="{Binding SolvedProblems}"
                                        Width="0.9*"
                                        MinWidth="80" />
                    <DataGridTextColumn Header="Spr&#xE1;vn&#x11B;"
                                        Binding="{Binding CorrectAnswers}"
                                        Width="0.9*"
                                        MinWidth="80" />
                    <DataGridTextColumn Header="&#xDA;sp&#x11B;&#x161;nost"
                                        Binding="{Binding AccuracyPercent, StringFormat={}{0:F1} %}"
                                        Width="1*"
                                        MinWidth="95" />
                    <DataGridTextColumn Header="Trend"
                                        Binding="{Binding ImprovementTrend, StringFormat={}{0:F1}}"
                                        Width="0.8*"
                                        MinWidth="75" />
                    <DataGridTextColumn Header="Posledn&#xED; aktivita"
                                        Binding="{Binding LastActivityDateDisplay}"
                                        Width="1.1*"
                                        MinWidth="110" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
