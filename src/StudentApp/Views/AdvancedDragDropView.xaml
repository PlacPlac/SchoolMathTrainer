<UserControl x:Class="StudentApp.Views.AdvancedDragDropView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}"
            Margin="4"
            Padding="8"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid MaxWidth="860"
              HorizontalAlignment="Center"
              VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="126" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Pokročilý"
                               Style="{StaticResource SectionTitleStyle}" />
                    <StackPanel Grid.Column="1"
                                Margin="14,0,0,0">
                        <TextBlock Text="Přetáhni správné číslo do cílového políčka nebo klepni na číselnou kartičku."
                                   Style="{StaticResource SubtitleStyle}"
                               FontSize="14" />
                        <TextBlock Text="{Binding ScoreLine}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Expression}"
                               Style="{StaticResource BigEquationStyle}"
                               FontSize="24" />
                    <Border Width="210"
                            Height="52"
                            Margin="0,2,0,2"
                            Background="{StaticResource SoftYellowBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="3"
                            CornerRadius="18"
                            AllowDrop="True"
                            Drop="DropZone_Drop">
                        <TextBlock Text="{Binding DropHint}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>
                    <TextBlock Text="{Binding FeedbackMessage}"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               TextAlignment="Center"
                               FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FeedbackState}"
                                                 Value="Success">
                                        <Setter Property="Foreground"
                                                Value="#1F8A47" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FeedbackState}"
                                                 Value="Error">
                                        <Setter Property="Foreground"
                                                Value="#C33D2B" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Vyber číslo nebo ho přetáhni do cílové oblasti."
                           Style="{StaticResource SubtitleStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2"
                           FontSize="13" />

                <Border Grid.Row="3"
                        Background="{StaticResource SoftGreenBrush}"
                        CornerRadius="22"
                        Padding="4"
                        MinWidth="620"
                        MaxWidth="760"
                        MinHeight="116"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        IsEnabled="{Binding IsRoundActive}">
                    <ItemsControl ItemsSource="{Binding NumberTiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" Rows="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="5"
                                        Padding="2"
                                        Width="98"
                                        Height="40"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Content="{Binding}"
                                        Click="NumberTile_Click"
                                        PreviewMouseLeftButtonDown="NumberTile_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="NumberTile_PreviewMouseMove"
                                        Style="{StaticResource AnswerButtonStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>

            <Grid IsHitTestVisible="{Binding IsRoundSummaryVisible}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRoundSummaryVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="2"
                        CornerRadius="22"
                        Padding="24"
                        MaxWidth="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,-54,0,0">
                    <StackPanel>
                        <TextBlock Text="Kolo dokončeno"
                                   Style="{StaticResource SectionTitleStyle}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{Binding RoundSummary}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="{Binding RoundSaveStatus}"
                                   Style="{StaticResource SubtitleStyle}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button Content="Nové kolo"
                                    Command="{Binding StartNewRoundCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="160"
                                    Margin="0,0,10,0" />
                            <Button Content="Zpět"
                                    Command="{Binding BackCommand}"
                                    Style="{StaticResource AnswerButtonStyle}"
                                    Width="130" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
