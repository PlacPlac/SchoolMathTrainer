<UserControl x:Class="StudentApp.Views.StudentLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel MaxWidth="760"
                        HorizontalAlignment="Left">
                <TextBlock Text="Přihlášení žáka" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="{Binding WelcomeMessage}"
                           Style="{StaticResource SubtitleStyle}"
                           Margin="0,8,0,0" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="-18,18,0,0"
                    Padding="18"
                    Background="{StaticResource SoftBlueBrush}"
                    BorderBrush="{StaticResource SoftLineBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock Text="{Binding LoadedStudentFileText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Zadej přihlašovací kód a PIN pro tohoto žáka."
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,6,0,0" />
                    <TextBlock Text="Přihlašovací kód musí odpovídat načtenému souboru."
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <WrapPanel Grid.Row="2"
                       Margin="0,22,0,0"
                       ItemWidth="230"
                       MinHeight="82">
                <StackPanel Margin="0,0,16,14">
                    <TextBlock Text="Přihlašovací kód" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox MinWidth="210"
                             ToolTip="Přihlašovací kód"
                             Text="{Binding LoginCode, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="0,0,16,14">
                    <TextBlock Text="PIN" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox MinWidth="150"
                             MaxLength="4"
                             ToolTip="PIN"
                             Text="{Binding Pin, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="0,0,16,14">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewPinRequired}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Nový PIN" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox MinWidth="150"
                             MaxLength="4"
                             ToolTip="Nový PIN"
                             Text="{Binding NewPin, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </WrapPanel>

            <WrapPanel Grid.Row="3"
                       Margin="0,4,0,0">
                <Button Width="190"
                        Content="Vstoupit"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,12,10" />
                <Button MinWidth="170"
                        Content="Změnit žáka"
                        Command="{Binding DataContext.ChangeStudentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource QuietButtonStyle}"
                        Margin="0,0,12,10" />
                <Button MinWidth="120"
                        Content="Zavřít"
                        Command="{Binding DataContext.CloseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource QuietButtonStyle}"
                        Margin="0,0,0,10" />
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
