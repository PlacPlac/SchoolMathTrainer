<UserControl x:Class="StudentApp.Views.StudentLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,20,0">
                <TextBlock Text="Přihlášení žáka" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="{Binding WelcomeMessage}" Style="{StaticResource SubtitleStyle}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Margin="0,0,12,0">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Přihlašovací kód" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Width="135"
                             VerticalContentAlignment="Center"
                             FontSize="20"
                             ToolTip="Přihlašovací kód"
                             Text="{Binding LoginCode, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="PIN" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Width="86"
                             MaxLength="4"
                             VerticalContentAlignment="Center"
                             FontSize="20"
                             ToolTip="PIN"
                             Text="{Binding Pin, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewPinRequired}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Nový PIN" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Width="96"
                             MaxLength="4"
                             VerticalContentAlignment="Center"
                             FontSize="20"
                             ToolTip="Nový PIN"
                             Text="{Binding NewPin, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="2"
                    Width="178"
                    Content="Vstoupit"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </Grid>
    </Border>
</UserControl>
